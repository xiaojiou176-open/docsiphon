{
  "name": "Docsiphon",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "uv sync --group dev",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/${localWorkspaceFolderBasename}/.venv/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
